# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Environment
.env
.env*.local
.venv/
venv/

# Config with secrets (use annas_config.example.json as template)
src/annas_config.json

# Databases (local data, not tracked)
*.db
*.db-wal
*.db-shm

# Downloads (download OUTPUT dirs only — not the app's source route)
downloads/
downloads_*/
# The broad downloads/ rule above also matches the renderer's source route dir;
# keep that tracked (re-include the dir, then its files).
!web/src/app/downloads/
!web/src/app/downloads/**

# Logs
*.log
*.log.*

# Linter / type checker caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
coverage.xml
.coverage

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Frontend
node_modules/
web/.next/
web/out/

# Electron app build artifacts
electron-app/dist/
electron-app/release/
electron-app/renderer/
electron-app/python-dist/

# Compressed data (too large for git)
data/*.jsonl.zst

# Agent / code-review tooling (per-session, machine-specific; not app source)
.codex/
.greptile/
